{
    "manifest_version": 3,
    "name": "PathMiner",
    "version": "1.0",
    "description": "Endpoint discovery and scoring for the current site.",
    "permissions": ["scripting", "activeTab", "storage", "webRequest"],
    "host_permissions": ["<all_urls>"],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
      },
      "default_title": "Run PathMiner"
    }
  }
  
